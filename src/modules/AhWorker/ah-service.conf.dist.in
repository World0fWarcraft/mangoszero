[AhServiceConf]
ConfVersion=@MANGOS_AHBOT_VER@
Console.ShowOnStartup = 0
LogLevel = 1

###############################################################################
# AH-SERVICE INFRASTRUCTURE
#
#    WorldDatabaseInfo
#        World database connection string. Same host;port;user;pass;db format
#        as mangosd.conf. The ah-service child opens its OWN world-DB
#        connection (mangosd's connection is separate) and only ever issues
#        SELECTs against it.
#
#        SECURITY: do NOT copy mangosd's full read/write credentials here. The
#        child is untrusted (that is WHY mangosd re-validates every intent); a
#        compromised child holding write-capable creds could write the DB
#        directly and bypass the executor. Provision a DEDICATED least-privilege
#        MySQL account with SELECT-only grants for this connection. See the
#        "Security" section of doc/AuctionHouseBot.md for example GRANT
#        statements.
#    Default: "" (disabled)
#
#    Example (point at a SELECT-only account, not mangosd's user):
#    WorldDatabaseInfo = "127.0.0.1;3306;ahbot_ro;change-me;mangos0"

WorldDatabaseInfo = ""

#
#    WorldDatabaseConnections
#        Number of additional asynchronous world-DB connections (a synchronous
#        connection is always created on top of this count).
#    Default: 1

WorldDatabaseConnections = 1

#
#    CharacterDatabaseInfo
#        Character database connection string. Same host;port;user;pass;db
#        format as mangosd.conf. The ah-service child opens its OWN character-DB
#        connection. It reads the live auction tables in both modes. With
#        WriteAuthority enabled it also writes the auction book and worker
#        journal directly.
#
#        SECURITY: use a DEDICATED least-privilege MySQL account, not mangosd's
#        full read/write credentials. Read-only service mode needs SELECT only.
#        WriteAuthority additionally requires INSERT, UPDATE, and DELETE on
#        exactly `auction` and `ah_worker_journal`, plus SELECT on
#        `custody_ledger` for safe journal retention. See "Worker DB grant
#        delta" in doc/AuctionHouseBot.md.
#    Default: "" (disabled)
#
#    Example (point at the mode-appropriate dedicated account):
#    CharacterDatabaseInfo = "127.0.0.1;3306;ahworker;change-me;character0"

CharacterDatabaseInfo = ""

#
#    CharacterDatabaseConnections
#        Number of additional asynchronous character-DB connections in the
#        SHARED round-robin pool (a synchronous connection is always created on
#        top). SP-1's dedicated browse thread runs its on-demand SELECTs through
#        this pool (with its own per-thread mysql_thread_init), so a floor of 2
#        gives the browse path headroom alongside the bot snapshot. This does
#        NOT dedicate a connection to the browse thread; it sizes the pool.
#    Default: 2

CharacterDatabaseConnections = 2

#
#    AhBot.ConfigPath
#        Path to the auction-house bot tuning config (ahbot.conf). May be
#        relative to the ah-service working directory or absolute.
#    Default: ahbot.conf

AhBot.ConfigPath = ahbot.conf

#
#    AhBot.DryRun
#        When 1 the child still makes auction decisions on its cadence but
#        LOGS each intent (opcode + key fields) instead of sending it to
#        mangosd. The child is always read-only on the DB; this only governs
#        whether decided intents are transmitted.
#    Default: 0 (emit intents)

AhBot.DryRun = 0

#
#    AhBot.UpdateIntervalMs
#        Bot decision cadence in milliseconds. Matches the in-process bot's
#        20s WUPDATE_AHBOT tick by default; one rotated operation (one house,
#        seller or buyer) runs per tick.
#    Default: 20000

AhBot.UpdateIntervalMs = 20000

#
#    AH.Service.TickMs
#        [SP-2] Mutation-tick cadence in milliseconds, on the IPC_GAMETIME-synced
#        game clock. Under WriteAuthority the worker runs the expiry/win tick on
#        this interval (auctions past expireTime resolve as won/no-bid). Lower =
#        tighter expiry latency at more DB churn; 1000 tracks the legacy
#        minute-class sweep comfortably.
#    Default: 1000

AH.Service.TickMs = 1000

#
#    AH.Service.JournalPruneIntervalSec
#        [SP-3] Worker-journal maintenance cadence in seconds. When
#        WriteAuthority is active, the worker starts a terminal-row retention
#        pass on startup and then on this interval. Large backlogs drain in
#        fixed batches between IPC dispatch passes. Set to 0 to disable pruning.
#    Default: 3600

AH.Service.JournalPruneIntervalSec = 3600

#
#    AH.Service.JournalTerminalRetentionSec
#        [SP-3] Retention window for terminal ah_worker_journal rows.
#        JRN_COMMITTED uses created_time; JRN_APPLIED uses resolved_time.
#        COMMITTED rows remain protected while their auction has RESERVED
#        custody needed for lost-reply reconciliation. APPLIED rows remain
#        protected while custody_ledger contains their resolve:<uuid> or
#        botlist:<uuid> idempotency marker. RESOLVING, CANCEL_PREPARED, and
#        INTENT_PENDING rows are never deleted by this pass. Set to 0 to disable
#        pruning. Configurations staged from an earlier version of this feature
#        retain AH.Service.JournalAppliedRetentionSec as a fallback; this
#        terminal setting takes precedence when both are present.
#    Default: 2592000 (30 days)

AH.Service.JournalTerminalRetentionSec = 2592000

###############################################################################
